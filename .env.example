# ── Captura de leads (/contato) — configurar na Vercel (Project → Settings → Environment Variables)
# Sem estas vars o formulário NÃO grava/envia: ele recusa o envio e orienta
# o usuário a WhatsApp/e-mail (nada é perdido silenciosamente).

# Supabase (mesmo projeto do Mentor IA, schema isolado "marketing", RLS off,
# insert só via Server Action → usar a SERVICE ROLE KEY, server-only):
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (e-mail transacional; domínio vertho.ai verificado no Resend):
RESEND_API_KEY=
# Remetente verificado e destinatários internos (separados por vírgula):
CONTACT_FROM="Site Vertho <contato@vertho.ai>"
CONTACT_TO="rodrigo@vertho.ai,samuel@vertho.ai,juliane@vertho.ai"

# Cloudflare Turnstile (anti-spam). Sem estas, o widget não aparece e a
# verificação é pulada (dev). Em produção, configurar ambas:
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google Analytics 4 (opcional; sem ID o GA não é injetado):
NEXT_PUBLIC_GA_ID=
